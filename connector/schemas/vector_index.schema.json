{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/aoa-4pda/vector_index.schema.json",
  "title": "AoA 4PDA Vector Index",
  "type": "object",
  "required": ["schema", "profile_id", "unit", "algorithm", "dimensions", "doc_count", "docs"],
  "properties": {
    "schema": { "const": "aoa_4pda_vector_index_v1" },
    "profile_id": { "type": "string", "minLength": 1 },
    "unit": { "const": "chunk" },
    "algorithm": { "type": "string", "minLength": 1 },
    "dimensions": { "type": "integer", "minimum": 1 },
    "built_at": { "type": "string" },
    "doc_count": { "type": "integer", "minimum": 0 },
    "feature_count": { "type": "integer", "minimum": 0 },
    "docs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["doc_id", "chunk_id", "vector"],
        "properties": {
          "doc_id": { "type": "string" },
          "chunk_id": { "type": "string" },
          "post_id": { "type": ["string", "null"] },
          "topic_id": { "type": ["string", "null"] },
          "source_url": { "type": ["string", "null"] },
          "vector": { "type": "object", "additionalProperties": { "type": "number" } }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
