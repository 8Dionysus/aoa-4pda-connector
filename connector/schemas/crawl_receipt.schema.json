{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/aoa-4pda/crawl_receipt.schema.json",
  "title": "AoA 4PDA Crawl Receipt",
  "type": "object",
  "required": ["schema", "run_id", "profile_id", "started_at", "source_urls", "policy"],
  "properties": {
    "schema": { "const": "aoa_4pda_crawl_receipt_v1" },
    "run_id": { "type": "string", "minLength": 1 },
    "profile_id": { "type": "string", "minLength": 1 },
    "started_at": { "type": "string" },
    "finished_at": { "type": ["string", "null"] },
    "source_urls": { "type": "array", "items": { "type": "string" } },
    "policy": {
      "type": "object",
      "required": ["allowed_public_only", "internal_search_used", "attachments_downloaded"],
      "properties": {
        "allowed_public_only": { "type": "boolean" },
        "internal_search_used": { "type": "boolean" },
        "attachments_downloaded": { "type": "boolean" }
      }
    },
    "counts": { "type": "object" }
  },
  "additionalProperties": true
}

