{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/aoa-4pda/answer_packet.schema.json",
  "title": "AoA 4PDA Answer Packet",
  "type": "object",
  "required": [
    "schema",
    "answer_id",
    "query",
    "created_at",
    "answer_report",
    "answers",
    "evidence_chain",
    "nuance_report",
    "agent_answer",
    "policy"
  ],
  "properties": {
    "schema": { "const": "aoa_4pda_answer_packet_v1" },
    "answer_id": { "type": "string", "minLength": 1 },
    "query": { "type": "string" },
    "created_at": { "type": ["string", "null"] },
    "answer_report": {
      "type": "object",
      "required": [
        "renderer",
        "source_packet_id",
        "source_packet_schema",
        "answer_status",
        "candidate_result_count",
        "grounded_candidate_count",
        "filtered_candidate_count",
        "deduplicated_candidate_count"
      ],
      "properties": {
        "renderer": { "enum": ["starter_graph_context_v1", "starter_graph_context_v2"] },
        "source_packet_id": { "type": ["string", "null"] },
        "source_packet_schema": { "type": ["string", "null"] },
        "query_algorithm": { "type": ["string", "null"] },
        "graph_context_required": { "type": "boolean" },
        "freshness_context": { "type": "string" },
        "answer_status": { "enum": ["answered", "insufficient_evidence"] },
        "gap_reason": {
          "type": ["string", "null"],
          "enum": [
            "no_candidate_evidence",
            "unmatched_structured_query_terms",
            "candidate_evidence_below_grounding_threshold",
            null
          ]
        },
        "missing_evidence_note": { "type": ["string", "null"] },
        "candidate_result_count": { "type": "integer", "minimum": 0 },
        "grounded_candidate_count": { "type": "integer", "minimum": 0 },
        "filtered_candidate_count": { "type": "integer", "minimum": 0 },
        "deduplicated_candidate_count": { "type": "integer", "minimum": 0 },
        "top_evidence_grounding": {
          "type": "object",
          "properties": {
            "content_terms": { "type": "array", "items": { "type": "string" } },
            "matched_content_terms": { "type": "array", "items": { "type": "string" } },
            "matched_content_term_count": { "type": "integer", "minimum": 0 },
            "unmatched_structured_terms": { "type": "array", "items": { "type": "string" } },
            "relation_supported": { "type": "boolean" },
            "content_phrase_supported": { "type": "boolean" }
          }
        },
        "primary_evidence_grounding": {
          "type": ["object", "null"],
          "properties": {
            "content_terms": { "type": "array", "items": { "type": "string" } },
            "matched_content_terms": { "type": "array", "items": { "type": "string" } },
            "matched_content_term_count": { "type": "integer", "minimum": 0 },
            "unmatched_structured_terms": { "type": "array", "items": { "type": "string" } },
            "relation_supported": { "type": "boolean" },
            "content_phrase_supported": { "type": "boolean" }
          }
        }
      }
    },
    "answers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "answer_kind",
          "answer_text",
          "source_url",
          "posted_at",
          "captured_at",
          "evidence_refs",
          "freshness",
          "confidence"
        ],
        "properties": {
          "answer_kind": { "type": "string" },
          "answer_text": { "type": "string" },
          "source_url": { "type": ["string", "null"] },
          "topic_id": { "type": ["string", "null"] },
          "post_id": { "type": ["string", "null"] },
          "posted_at": { "type": ["string", "null"] },
          "captured_at": { "type": ["string", "null"] },
          "chunk_id": { "type": ["string", "null"] },
          "score": { "type": ["number", "null"] },
          "issue_labels": { "type": "array", "items": { "type": "string" } },
          "fix_labels": { "type": "array", "items": { "type": "string" } },
          "warning_labels": { "type": "array", "items": { "type": "string" } },
          "warned_target_labels": { "type": "array", "items": { "type": "string" } },
          "root_action_labels": { "type": "array", "items": { "type": "string" } },
          "recovery_action_labels": { "type": "array", "items": { "type": "string" } },
          "target_file_labels": { "type": "array", "items": { "type": "string" } },
          "tool_labels": { "type": "array", "items": { "type": "string" } },
          "firmware_context_labels": { "type": "array", "items": { "type": "string" } },
          "evidence_refs": { "type": "array", "items": { "type": "string" } },
          "source_refs": { "type": "array", "items": { "type": ["string", "null"] } },
          "freshness": {
            "type": "object",
            "required": ["basis", "posted_at", "captured_at", "packet_created_at", "note"],
            "properties": {
              "basis": { "type": "string" },
              "posted_at": { "type": ["string", "null"] },
              "captured_at": { "type": ["string", "null"] },
              "packet_created_at": { "type": ["string", "null"] },
              "note": { "type": "string" }
            }
          },
          "confidence": { "type": "object" }
        }
      }
    },
    "evidence_chain": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "chain_step",
          "role",
          "answer_kind",
          "summary",
          "source_url",
          "topic_id",
          "post_id",
          "chunk_id",
          "posted_at",
          "captured_at",
          "freshness",
          "evidence_refs",
          "source_refs",
          "matched_terms",
          "matched_exact_terms",
          "matched_specific_terms",
          "matched_content_terms",
          "relation_kinds",
          "score"
        ],
        "properties": {
          "chain_step": { "type": "integer", "minimum": 1 },
          "role": { "enum": ["primary", "supporting", "caution", "related_context"] },
          "answer_kind": { "type": ["string", "null"] },
          "summary": { "type": ["string", "null"] },
          "source_url": { "type": ["string", "null"] },
          "topic_id": { "type": ["string", "null"] },
          "post_id": { "type": ["string", "null"] },
          "chunk_id": { "type": ["string", "null"] },
          "posted_at": { "type": ["string", "null"] },
          "captured_at": { "type": ["string", "null"] },
          "freshness": { "type": "object" },
          "evidence_refs": { "type": "array", "items": { "type": "string" } },
          "source_refs": { "type": "array", "items": { "type": ["string", "null"] } },
          "matched_terms": { "type": "array", "items": { "type": "string" } },
          "matched_exact_terms": { "type": "array", "items": { "type": "string" } },
          "matched_specific_terms": { "type": "array", "items": { "type": "string" } },
          "matched_content_terms": { "type": "array", "items": { "type": "string" } },
          "relation_kinds": { "type": "array", "items": { "type": "string" } },
          "score": { "type": ["number", "null"] }
        }
      }
    },
    "nuance_report": {
      "type": "object",
      "required": [
        "chain_step_count",
        "topic_count",
        "post_count",
        "source_count",
        "answer_kinds",
        "relation_kinds",
        "matched_content_terms",
        "freshness",
        "limitations"
      ],
      "properties": {
        "chain_step_count": { "type": "integer", "minimum": 0 },
        "topic_count": { "type": "integer", "minimum": 0 },
        "post_count": { "type": "integer", "minimum": 0 },
        "source_count": { "type": "integer", "minimum": 0 },
        "answer_kinds": { "type": "array", "items": { "type": "string" } },
        "relation_kinds": { "type": "array", "items": { "type": "string" } },
        "matched_content_terms": { "type": "array", "items": { "type": "string" } },
        "freshness": {
          "type": "object",
          "required": ["basis", "latest_captured_at", "captured_at_values", "posted_at_values"],
          "properties": {
            "basis": { "type": "string" },
            "latest_captured_at": { "type": ["string", "null"] },
            "captured_at_values": { "type": "array", "items": { "type": "string" } },
            "posted_at_values": { "type": "array", "items": { "type": "string" } }
          }
        },
        "limitations": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["kind", "count"],
            "properties": {
              "kind": { "type": "string" },
              "count": { "type": "integer", "minimum": 1 }
            }
          }
        }
      }
    },
    "agent_answer": {
      "type": "object",
      "required": [
        "format",
        "status",
        "language",
        "query",
        "text",
        "citations",
        "freshness",
        "limitations"
      ],
      "properties": {
        "format": { "const": "deterministic_cited_brief_v1" },
        "status": { "enum": ["answered", "insufficient_evidence"] },
        "language": { "type": "string" },
        "query": { "type": "string" },
        "text": { "type": "string" },
        "citations": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["ref", "role", "topic_id", "post_id", "chunk_id", "source_url", "posted_at", "captured_at"],
            "properties": {
              "ref": { "type": "string" },
              "role": { "type": ["string", "null"] },
              "topic_id": { "type": ["string", "null"] },
              "post_id": { "type": ["string", "null"] },
              "chunk_id": { "type": ["string", "null"] },
              "source_url": { "type": ["string", "null"] },
              "posted_at": { "type": ["string", "null"] },
              "captured_at": { "type": ["string", "null"] },
              "evidence_refs": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "freshness": { "type": "object" },
        "limitations": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["kind", "count"],
            "properties": {
              "kind": { "type": "string" },
              "count": { "type": "integer", "minimum": 1 }
            }
          }
        }
      }
    },
    "policy": {
      "type": "object",
      "required": ["source", "internal_search_used"],
      "properties": {
        "source": { "const": "local_keyword_index_plus_graph_answer_renderer" },
        "internal_search_used": { "type": "boolean" }
      }
    }
  },
  "additionalProperties": true
}
