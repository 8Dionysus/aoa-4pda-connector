{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/aoa-4pda/normalized_post.schema.json",
  "title": "AoA 4PDA Normalized Post",
  "type": "object",
  "required": ["schema", "post_id", "topic_id", "source_url", "captured_at", "text"],
  "properties": {
    "schema": { "const": "aoa_4pda_normalized_post_v1" },
    "post_id": { "type": "string", "minLength": 1 },
    "topic_id": { "type": "string", "minLength": 1 },
    "source_url": { "type": "string" },
    "author_label": { "type": ["string", "null"] },
    "posted_at": { "type": ["string", "null"] },
    "captured_at": { "type": "string" },
    "text": { "type": "string" },
    "entities": { "type": "array", "items": { "type": "object" } }
  },
  "additionalProperties": true
}

