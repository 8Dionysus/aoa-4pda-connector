# Copy to .env or export these values in your shell.
#
# The portable default is repo-local ignored state. This is useful for small
# starter runs on machines that have enough local disk. Move these roots to
# external storage when the database grows beyond bounded experiments.

CONNECTOR_DATA_ROOT=.connector-state/data
CONNECTOR_CACHE_ROOT=.connector-state/cache
CONNECTOR_ARTIFACT_ROOT=.connector-state/artifacts

# External storage example:
# CONNECTOR_DATA_ROOT=/path/to/storage/aoa-4pda-connector/data
# CONNECTOR_CACHE_ROOT=/path/to/storage/aoa-4pda-connector/cache
# CONNECTOR_ARTIFACT_ROOT=/path/to/storage/aoa-4pda-connector/artifacts

# Optional operator identity for polite public-page fetches.
CONNECTOR_USER_AGENT=aoa-4pda-connector/0.1 (+https://github.com/8Dionysus/aoa-4pda-connector)
