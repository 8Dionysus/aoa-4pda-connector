# Python
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
dist/
build/
*.egg-info/

# Local environment
.env

# Repo-local connector state.
# Keep route cards and empty directory anchors, ignore all generated content.
.connector-state/
.connector-state/**

# Heavy connector data: never commit.
data/
cache/
artifacts/
raw/
indexes/
vectors/
graphs/
exports/full/
!kag/indexes/
!kag/indexes/*.json
*.sqlite
*.sqlite3
*.sqlite-wal
*.sqlite-shm
*.db
*.parquet
*.arrow
*.faiss
*.ann
*.hnsw
*.qdrant/
*.lancedb/
*.chromadb/
*.weaviate/
*.milvus/

# Runtime receipts may be copied out separately when needed.
logs/

# Keep the repo-local state scaffold tracked after broad heavy-data ignores.
!.connector-state/
!.connector-state/README.md
!.connector-state/AGENTS.md
!.connector-state/**/
!.connector-state/**/.gitkeep
